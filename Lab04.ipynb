    "import networkx as nx\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "G = nx.DiGraph()\n",
    "\n",
    "root = \"Estado inicial\"\n",
    "G.add_node(root)\n",
    "\n",
    "level1 = []\n",
    "level2 = []\n",
    "\n",
    "# Nivel 1\n",
    "for i in range(1,10):\n",
    "    child = f\"x1={i}\"\n",
    "    G.add_edge(root, child)\n",
    "    level1.append(child)\n",
    "\n",
    "# Nivel 2\n",
    "for node in level1:\n",
    "    for j in range(1,4):\n",
    "        child = f\"{node}, x2={j}\"\n",
    "        G.add_edge(node, child)\n",
    "        level2.append(child)\n",
    "\n",
    "pos = {}\n",
    "\n",
    "pos[root] = (0,0)\n",
    "\n",
    "x_spacing = 2\n",
    "for i,node in enumerate(level1):\n",
    "    pos[node] = (i*x_spacing-8, -2)\n",
    "\n",
